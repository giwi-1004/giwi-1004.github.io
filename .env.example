# Environment variables (build time — GitHub Actions Secrets 또는 로컬 .env.local)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# 또는 정적 배포(GitHub Pages)용: public/supabase-config.json 생성
# public/supabase-config.example.json 을 복사해 실제 URL·anon 키 입력 후 커밋/배포
